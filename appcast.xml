<?xml version="1.0" standalone="yes"?>
<rss xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle"
     xmlns:dc="http://purl.org/dc/elements/1.1/" version="2.0">
    <channel>
        <title>CAR Host</title>
        <link>https://parslee-ai.github.io/car-releases/appcast.xml</link>
        <description>CAR — Common Agent Runtime in-app updates</description>
        <language>en</language>
        <!--
            Per-release <item> entries get appended here, newest first.
            Sparkle parses items in document order and treats the most
            recent <pubDate> as latest.

            Each entry is generated by:
                bash scripts/generate-appcast-entry.sh \
                    --zip <signed-notarized-zip> \
                    --private-key <sparkle-ed25519-key> \
                    --url <github-release-download-url> \
                    --release-notes-url <github-release-tag-url>

            See docs/sparkle-release-flow.md in Parslee-ai/car for the
            full per-release procedure. The first <item> lands when the
            release after Sparkle activation cuts.
        -->
    </channel>
</rss>
